# SocialMedia AI backend config
# Never commit your real password or secrets. Add these in Railway Variables.
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=use-a-strong-password-here
SECRET_KEY=generate-a-long-random-secret-key
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_PATH=backend/socialmedia.sqlite3

# Meta OAuth setup
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v19.0
META_SCOPES=instagram_basic,instagram_content_publish,pages_show_list,pages_read_engagement
META_REDIRECT_URI=http://localhost:8000/oauth/meta/callback
FRONTEND_URL=http://localhost:5173
